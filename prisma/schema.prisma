// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String  @id @default(cuid())
  appwriteUserId  String  @unique
  email           String  @unique
  name            String?
  passwordHash    String?
  passwordSet     Boolean @default(false)
  prn             String?
  roll            String?
  division        String?
  profileComplete Boolean @default(false)

  clubRoles        UserClubRole[]
  clubJoinRequests ClubJoinRequest[] @relation("UserRequests")
  reviewedRequests ClubJoinRequest[] @relation("ReviewedRequests")
}

model Club {
  id              String @id @default(cuid())
  name            String @unique
  description     String
  clubCoordinator String

  members          UserClubRole[]
  clubJoinRequests ClubJoinRequest[]

  events Event[]
}

model UserClubRole {
  id String @id @default(cuid())

  userId String
  clubId String
  role   Role

  user User @relation(fields: [userId], references: [id])
  club Club @relation(fields: [clubId], references: [id])

  @@unique([userId, clubId, role])
}

model ClubJoinRequest {
  id String @id @default(cuid())

  userId String
  clubId String
  role   Role

  status RequestStatus @default(PENDING)

  message String?

  reviewedById String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())

  user       User  @relation("UserRequests", fields: [userId], references: [id])
  club       Club  @relation(fields: [clubId], references: [id])
  reviewedBy User? @relation("ReviewedRequests", fields: [reviewedById], references: [id])

  @@unique([userId, clubId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  CLUB_MEMBER
  CLUB_HEAD
}

model Event {
  id String @id @default(cuid())

  clubId String
  club   Club @relation(fields: [clubId], references: [id])

  name        String
  description String?
  venue       String
  date        DateTime
  duration    String?

  hostName String

  contactEmail  String?
  contactPhones String[]

  registrationLink String?

  brochureUrl String?

  speakers Speaker[]   // ✅ MULTIPLE SPEAKERS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Speaker {
  id String @id @default(cuid())

  name String
  linkedin String?
  github String?

  eventId String
  event   Event @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())
}