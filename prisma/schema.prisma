generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  passwordHash     String?
  passwordSet      Boolean           @default(false)
  prn              String?
  roll             String?
  division         String?
  profileComplete  Boolean           @default(false)
  reviewedRequests ClubJoinRequest[] @relation("ReviewedRequests")
  clubJoinRequests ClubJoinRequest[] @relation("UserRequests")
  deletedEvents    DeletedEvent[]
  clubRoles        UserClubRole[]
}

model Otp {
  id         String   @id @default(cuid())
  otp        String   @unique
  email      String   @unique
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}

model Club {
  id               String            @id @default(cuid())
  name             String            @unique
  description      String
  clubCoordinator  String
  clubJoinRequests ClubJoinRequest[]
  deletedEvents    DeletedEvent[]
  events           Event[]
  members          UserClubRole[]
}

model UserClubRole {
  id     String @id @default(cuid())
  userId String
  clubId String
  role   Role
  club   Club   @relation(fields: [clubId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, clubId, role])
}

model ClubJoinRequest {
  id           String        @id @default(cuid())
  userId       String
  clubId       String
  role         Role
  status       RequestStatus @default(PENDING)
  message      String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime      @default(now())
  club         Club          @relation(fields: [clubId], references: [id])
  reviewedBy   User?         @relation("ReviewedRequests", fields: [reviewedById], references: [id])
  user         User          @relation("UserRequests", fields: [userId], references: [id])

  @@unique([userId, clubId])
}

model Event {
  id               String    @id @default(cuid())
  clubId           String
  name             String
  description      String?
  venue            String
  date             DateTime
  duration         String?
  hostName         String
  contactEmail     String?
  contactPhones    String[]
  registrationLink String?
  brochureUrl      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  club             Club      @relation(fields: [clubId], references: [id])
  speakers         Speaker[]
}

model Speaker {
  id        String   @id @default(cuid())
  name      String
  linkedin  String?
  github    String?
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
}

model DeletedEvent {
  id               String   @id @default(cuid())
  originalEventId  String
  clubId           String
  name             String
  description      String?
  venue            String
  date             DateTime
  duration         String?
  hostName         String
  contactEmail     String?
  contactPhones    String[]
  registrationLink String?
  brochureUrl      String?
  deletedByUserId  String
  deletedByRole    String
  deletedAt        DateTime @default(now())
  club             Club     @relation(fields: [clubId], references: [id])
  deletedByUser    User     @relation(fields: [deletedByUserId], references: [id])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  CLUB_MEMBER
  CLUB_HEAD
}
